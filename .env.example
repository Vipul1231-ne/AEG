# AegisTrap Environment Configuration Template
# Copy this file to '.env' and configure your secret key and overrides.

# [CRITICAL] Secret key for signing Flask sessions. Set a secure random key.
AEGISTRAP_DASHBOARD_SECRET_KEY="generate-a-secure-secret-key-here"

# --- Optional Overrides ---
# Uncomment any of these to override the settings in config/config.yaml

# Dashboard configuration
# Bind dashboard to 0.0.0.0 (required to access it outside of Docker containers)
# AEGISTRAP_DASHBOARD_HOST=0.0.0.0
# AEGISTRAP_DASHBOARD_PORT=5000

# Honeyport service ports
# AEGISTRAP_SSH_LISTEN_PORT=2222
# AEGISTRAP_FTP_LISTEN_PORT=2121
# AEGISTRAP_HTTP_LISTEN_PORT=8080
# AEGISTRAP_HTTPS_LISTEN_PORT=8443
